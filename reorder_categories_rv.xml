<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/list_outline_unselected"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:orientation="horizontal"
    android:visibility="visible">

    <TextView
        android:id="@+id/categoryName"
        android:layout_width="275dp"
        android:layout_height="36dp"
        android:layout_marginStart="25dp"
        android:translationY="-3dp"
        android:text="@string/name"
        android:textSize="24sp" />

    <!--Up/Down Arrows-->

    <ImageView
        android:id="@+id/triangleDown"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@mipmap/triangle_down"
        app:layout_constraintRight_toRightOf="parent"
        android:contentDescription="@string/triangleDown"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/triangleUp"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@mipmap/triangle_up"
        app:layout_constraintRight_toRightOf="parent"
        android:contentDescription="@string/triangleUp"
        android:visibility="gone" />

    <!--Drag and Drop-->

    <ImageView
        android:id="@+id/dragAndDropEmoji"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@mipmap/triangle_down"
        app:layout_constraintRight_toRightOf="parent"
        android:contentDescription="@string/dragAndDropEmojis"
        android:visibility="gone" />

    <!--With Numbers-->

    <EditText
        android:id="@+id/withNumbersEditText"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:hint="@string/space"
        android:background="@drawable/spinner_outline_1dp"
        android:inputType="number"
        android:visibility="visible" />

    <ImageView
        android:id="@+id/withNumbersRefreshButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@mipmap/refresh_icon"
        app:layout_constraintRight_toRightOf="parent"
        android:contentDescription="@string/refreshIcon"
        android:visibility="visible"/>

</LinearLayout>