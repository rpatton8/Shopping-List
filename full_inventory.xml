<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true"
    tools:context=".FullInventory">

    <TextView
        android:id="@+id/fullInventoryTitle"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@android:color/holo_blue_dark"
        android:text="@string/inventoryTitle"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/fullInventoryRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="620dp"
        android:paddingBottom="6dp"
        android:clipToPadding="false"
        android:visibility="visible"
        android:layout_below="@id/fullInventoryTitle" />

    <TextView
        android:id="@+id/addNewItemButton"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="3dp"
        android:background="@mipmap/plus_button" />

    <TextView
        android:id="@+id/searchButton"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="42dp"
        android:layout_marginTop="4dp"
        android:background="@mipmap/search_icon" />

    <LinearLayout
        android:id="@+id/searchPopup"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="2dp"
        android:layout_below="@id/searchButton"
        android:background="@android:color/holo_green_light"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/searchPrompt"
            android:layout_width="80dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:text="@string/searchWithColon"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/searchBox"
            android:layout_width="270dp"
            android:layout_height="match_parent"
            android:hint="@string/space"
            android:inputType="text"
            android:textSize="22sp"/>

        <TextView
            android:id="@+id/clearSearchButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:translationY="-14dp"
            android:background="@mipmap/clear_button" />

    </LinearLayout>

    <ImageView
        android:id="@+id/refreshButton"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginEnd="38dp"
        android:layout_marginTop="2dp"
        android:src="@mipmap/refresh_icon_blue" />

    <ImageView
        android:id="@+id/fullInventoryEditButton"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:src="@mipmap/edit_3dots"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchInventoryRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="570dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:clipToPadding="false"
        android:visibility="gone"
        android:layout_below="@id/searchPopup" />

    <LinearLayout
        android:id="@+id/individualCategoriesLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_horizontal"
        android:layout_below="@id/searchPopup"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal" >

            <TextView
                android:id="@+id/individualCategoriesLeftArrow"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="5dp"
                android:background="@mipmap/left_arrow_white" />

            <Spinner
                android:id="@+id/individualCategoriesSpinner"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:layout_gravity="center"
                android:background="@drawable/spinner_outline_2dp"
                android:gravity="center_horizontal"
                android:spinnerMode="dialog" />

            <TextView
                android:id="@+id/individualCategoriesRightArrow"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="5dp"
                android:background="@mipmap/right_arrow_white" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:background="@android:color/holo_blue_dark"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/individualCategoriesRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="547dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clipToPadding="false"
            android:visibility="gone"
            android:background="#FFFFFF" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/individualStoresLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_horizontal"
        android:layout_below="@id/searchPopup"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal" >

            <TextView
                android:id="@+id/individualStoresLeftArrow"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginTop="8dp"
                android:layout_marginEnd="5dp"
                android:background="@mipmap/left_arrow_white" />

            <Spinner
                android:id="@+id/individualStoresSpinner"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:layout_gravity="center"
                android:background="@drawable/spinner_outline_2dp"
                android:gravity="center_horizontal"
                android:spinnerMode="dialog" />

            <TextView
                android:id="@+id/individualStoresRightArrow"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginTop="8dp"
                android:layout_marginStart="5dp"
                android:background="@mipmap/right_arrow_white" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:background="@android:color/holo_blue_dark"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/individualStoresRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="540dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clipToPadding="false"
            android:visibility="gone"
            android:background="#FFFFFF" />

    </LinearLayout>

    <TextView
        android:id="@+id/fullInventoryOptionsBackground"
        android:layout_width="match_parent"
        android:layout_height="392dp"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/fullInventoryTitle"
        android:visibility="gone"
        android:background="@android:color/holo_green_light" />

    <Button
        android:id="@+id/sortAlphabetical"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="5dp"
        android:layout_marginTop="40dp"
        android:visibility="gone"
        android:textSize="18sp"
        android:text="@string/sortAlphabetically" />

    <Button
        android:id="@+id/sortByCategory"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="5dp"
        android:layout_marginTop="93dp"
        android:visibility="gone"
        android:textSize="18sp"
        android:text="@string/sortByCategory" />

    <Button
        android:id="@+id/sortByStore"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="5dp"
        android:layout_marginTop="146dp"
        android:visibility="gone"
        android:textSize="18sp"
        android:text="@string/sortByStore" />

    <Button
        android:id="@+id/viewAll"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginEnd="5dp"
        android:layout_marginTop="40dp"
        android:visibility="gone"
        android:textSize="16sp"
        android:text="@string/viewAll" />

    <Button
        android:id="@+id/viewInStock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginEnd="5dp"
        android:layout_marginTop="80dp"
        android:visibility="gone"
        android:textSize="16sp"
        android:text="@string/viewInStock" />

    <Button
        android:id="@+id/viewNeeded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginEnd="5dp"
        android:layout_marginTop="120dp"
        android:visibility="gone"
        android:textSize="16sp"
        android:text="@string/viewNeeded" />

    <Button
        android:id="@+id/viewPaused"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginEnd="5dp"
        android:layout_marginTop="160dp"
        android:visibility="gone"
        android:textSize="16sp"
        android:text="@string/viewPaused" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal" >

        <Button
            android:id="@+id/expandItems"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="200dp"
            android:visibility="gone"
            android:textSize="16sp"
            android:text="@string/expandItems" />

        <Button
            android:id="@+id/contractItems"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="200dp"
            android:visibility="gone"
            android:textSize="16sp"
            android:text="@string/contractItems" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal" >

        <Button
            android:id="@+id/expandCategories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="240dp"
            android:visibility="gone"
            android:textSize="16sp"
            android:text="@string/expandCategories" />

        <Button
            android:id="@+id/contractCategories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="240dp"
            android:visibility="gone"
            android:textSize="16sp"
            android:text="@string/contractCategories" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal" >

        <Button
            android:id="@+id/expandStores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="280dp"
            android:visibility="gone"
            android:textSize="16sp"
            android:text="@string/expandStores" />

        <Button
            android:id="@+id/contractStores"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="280dp"
            android:visibility="gone"
            android:textSize="16sp"
            android:text="@string/contractStores" />

    </LinearLayout>

    <Button
        android:id="@+id/individualCategories"
        android:layout_width="wrap_content"
        android:layout_height="55dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="323dp"
        android:visibility="gone"
        android:textSize="18sp"
        android:text="@string/individualCategories" />

    <Button
        android:id="@+id/individualStores"
        android:layout_width="wrap_content"
        android:layout_height="55dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="371dp"
        android:visibility="gone"
        android:textSize="18sp"
        android:text="@string/individualStores" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:orientation="vertical" >

        <TextView
            android:id="@+id/editDataBreak"
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:background="@android:color/holo_blue_dark"
            android:text="@string/item"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="2dp"
            android:layout_marginStart="2dp"
            android:orientation="horizontal"
            android:visibility="visible">

            <Button
                android:id="@+id/addPopup"
                android:layout_width="102dp"
                android:layout_height="48dp"
                android:text="@string/add"
                android:visibility="gone" />

            <Button
                android:id="@+id/editPopup"
                android:layout_width="102dp"
                android:layout_height="48dp"
                android:text="@string/edit"
                android:visibility="gone" />

            <Button
                android:id="@+id/removePopup"
                android:layout_width="102dp"
                android:layout_height="48dp"
                android:text="@string/remove"
                android:visibility="gone" />

            <Button
                android:id="@+id/reorderPopup"
                android:layout_width="102dp"
                android:layout_height="48dp"
                android:text="@string/reorder"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:background="@android:color/holo_blue_dark"
            android:text="@string/addEditRemoveReorder"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="2dp"
            android:layout_marginStart="2dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/addRemoveCategory"
                android:layout_width="136dp"
                android:layout_height="48dp"
                android:text="@string/category" />

            <Button
                android:id="@+id/addEditItem"
                android:layout_width="136dp"
                android:layout_height="48dp"
                android:text="@string/item" />

            <Button
                android:id="@+id/addRemoveStore"
                android:layout_width="136dp"
                android:layout_height="48dp"
                android:text="@string/store" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>