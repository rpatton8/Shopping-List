<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true"
    tools:context=".ReorderStores">

    <TextView
        android:id="@+id/reorderStores"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@android:color/holo_blue_dark"
        android:text="@string/reorderStores"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <android.support.v7.widget.RecyclerView
        android:id="@+id/reorderStoresRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="578dp"
        android:layout_below="@id/reorderStores"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="116dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="16dp"
            android:background="@android:color/holo_blue_dark"
            android:text="@string/space"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/finishReorderingButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/finishReordering" />

        <Button
            android:id="@+id/cancelButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/cancel" />

    </LinearLayout>

</RelativeLayout>