<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddItem">

    <TextView
        android:id="@+id/addItemTitle"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@android:color/holo_blue_dark"
        android:text="@string/addItem"
        android:textAlignment="center"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/addItemTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/item"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:layout_marginTop="6dp"
                    android:text="@string/enterItemName"
                    android:textSize="20sp"
                    android:textAlignment="center" />

                <EditText
                    android:id="@+id/itemNameInput"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="40dp"
                    android:hint="@string/space"
                    android:background="@drawable/spinner_outline_1dp"
                    android:inputType="text"
                    android:textSize="24sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/enterBrandType"
                    android:textSize="20sp"
                    android:textAlignment="center" />

                <EditText
                    android:id="@+id/itemBrandTypeInput"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="40dp"
                    android:hint="@string/space"
                    android:background="@drawable/spinner_outline_1dp"
                    android:inputType="text"
                    android:textSize="24sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/selectACategory"
                    android:textSize="20sp"
                    android:textAlignment="center" />

                <Spinner
                    android:id="@+id/categorySpinner"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:background="@drawable/spinner_outline_1dp"
                    android:spinnerMode="dialog" />

                <EditText
                    android:id="@+id/itemCategoryInput"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_margin="4dp"
                    android:layout_gravity="center"
                    android:hint="@string/space"
                    android:background="@drawable/spinner_outline_1dp"
                    android:visibility="gone"
                    android:inputType="text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/selectAStore"
                    android:textSize="20sp"
                    android:textAlignment="center" />

                <Spinner
                    android:id="@+id/storeSpinner"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_gravity="center"
                    android:background="@drawable/spinner_outline_1dp"
                    android:spinnerMode="dialog" />

                <EditText
                    android:id="@+id/itemStoreInput"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_margin="4dp"
                    android:layout_gravity="center"
                    android:hint="@string/space"
                    android:background="@drawable/spinner_outline_1dp"
                    android:visibility="gone"
                    android:inputType="text" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/status"
                    android:textSize="20sp"
                    android:textAlignment="center" />

                <TextView
                    android:id="@+id/inStockLabel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/bebas_regular"
                    android:text="@string/inStockCap"
                    android:textAlignment="center"
                    android:textColor="#00E432"
                    android:textSize="30sp"
                    android:visibility="visible"/>

                <TextView
                    android:id="@+id/neededLabel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/bebas_regular"
                    android:text="@string/needed"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_red_light"
                    android:textSize="30sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/pausedLabel"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/bebas_regular"
                    android:text="@string/paused"
                    android:textAlignment="center"
                    android:textColor="@android:color/holo_blue_bright"
                    android:textSize="30sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="16dp"
                    android:layout_marginTop="10dp"
                    android:background="@android:color/holo_blue_dark"/>

                <TextView
                    android:id="@+id/optionalDataTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/optionalData"
                    android:textSize="20sp"
                    android:textAlignment="center" />

                <TextView
                    android:id="@+id/quantityLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:layout_marginTop="6dp"
                    android:text="@string/quantity"
                    android:textSize="20sp"
                    android:textAlignment="center"
                    android:visibility="gone"/>

                <EditText
                    android:id="@+id/quantityInput"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="40dp"
                    android:hint="@string/space"
                    android:background="@drawable/spinner_outline_1dp"
                    android:inputType="text"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/priceLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/price"
                    android:textSize="20sp"
                    android:textAlignment="center"
                    android:visibility="gone"/>

                <EditText
                    android:id="@+id/priceInput"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="40dp"
                    android:hint="@string/space"
                    android:background="@drawable/spinner_outline_1dp"
                    android:inputType="text"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/locationLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:layout_marginTop="6dp"
                    android:text="@string/location"
                    android:textSize="20sp"
                    android:textAlignment="center"
                    android:visibility="gone"/>

                <EditText
                    android:id="@+id/locationInput"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="40dp"
                    android:hint="@string/space"
                    android:background="@drawable/spinner_outline_1dp"
                    android:inputType="text"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:visibility="gone"/>

                <TextView
                    android:id="@+id/noteLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:text="@string/note"
                    android:textSize="20sp"
                    android:textAlignment="center"
                    android:visibility="gone"/>

                <EditText
                    android:id="@+id/noteInput"
                    android:layout_width="330dp"
                    android:layout_height="42dp"
                    android:layout_marginStart="40dp"
                    android:layout_marginBottom="12dp"
                    android:hint="@string/space"
                    android:background="@drawable/spinner_outline_1dp"
                    android:inputType="text"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:visibility="gone"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:layout_marginTop="4dp"
                android:background="@android:color/holo_blue_dark"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/addItemButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/storeItemData"
                    android:layout_marginTop="10dp"
                    android:layout_marginLeft="10dp"
                    android:layout_marginRight="10dp" />

                <Button
                    android:id="@+id/cancelButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cancel"
                    android:layout_margin="10dp"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="16dp"
                android:background="@android:color/holo_blue_dark"/>

            <TextView
                android:layout_width="400dp"
                android:layout_height="320dp" />

        </LinearLayout>

    </ScrollView>

</RelativeLayout>